# .env.example — variables de entorno para producción (Coolify)
# Copia estas claves en la sección "Environment Variables" del servicio en Coolify.

SECRET_KEY=cambiar-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=dashboard.conluismz.com
CSRF_TRUSTED_ORIGINS=https://dashboard.conluismz.com

# Base de datos PostgreSQL (si DB_HOST está presente, Django usa Postgres en vez de SQLite)
DB_NAME=klynea
DB_USER=klynea_user
DB_PASSWORD=cambiar-por-una-contraseña-segura
DB_HOST=postgres
DB_PORT=5432
